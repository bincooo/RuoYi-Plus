/**
 * 由后台配置生成，不可手工修改
 */
import type { JSX } from "react";
import type { ProColumns } from "@ant-design/pro-components";
import type { TFunction } from "i18next";

type DictData = {
    label: string | JSX.Element;
    value: string | number;
    desc?: string;
};

type Merger<T> = (option: T) => T;

function merge<T>(columns: (T & { dataIndex: string })[], options?: { [column: string]: Merger<T & { dataIndex: string }> }): T[] {
    for (const i in columns) {
        const instance = options?.[columns[i].dataIndex];
        if (instance) {
            columns[i] = instance({ ...columns[i] });
        }
    }
    return columns;
}

export function getColumnList(t: TFunction<"translation", undefined>, options?: { [column: string]: Merger<ProColumns<${ModuleName}.${BusinessName}> & { dataIndex: string }> }#if(${dicts} != ""), dictMap?: { [column: string]: DictData[] }#end): ProColumns<${ModuleName}.${BusinessName}>[] {
    return merge([
        {
            dataIndex: "index",
            title: "序号",
            valueType: "index",
            fixed: "left",
            width: 80,
        },
#foreach($column in $columns)
    #if($column.isList == '1')
        #set($dictType=$column.dictType)
        #set($AttrName=$column.javaField.substring(0,1).toUpperCase() + ${column.javaField.substring(1)})
        #set($parentheseIndex=$column.columnComment.indexOf("（"))
        #if($parentheseIndex != -1)
            #set($comment=$column.columnComment.substring(0, $parentheseIndex))
        #else
            #set($comment=$column.columnComment)
        #end
        {
            title: "${comment}",
            dataIndex: "${column.javaField}",
            #if($column.isQuery != "1")
            search: false,
            #end
            proFieldProps: {
                placeholder: "请输入$comment",
            },
            #if($column.htmlType == "select" || $column.htmlType == "radio" || $column.htmlType == "checkbox")
            valueType: "select",
            #if($column.dictType != "" || $column.readConverterOpt().size() > 0)
            fieldProps: {
                options: [
                #if($column.dictType != "")
                    ...dictMap?.["$column.dictType"] ?? []
                #else
                #foreach($opt in $column.readConverterOpt())
                    { value: "$opt.value", label: "$opt.label" },
                #end
                #end
                ],
            },
            #end
            #elseif($column.htmlType == "datetime")
            valueType: "date",
            #end
        },
    #end
#end
    ], options);
}
