{
  "designerConfig": { "autoGenerateComponentId": false },
  "packages": {
    "@loccdn/antd": {
      "description": "低代码中后台应用基础物料",
      "version": "0.2.6",
      "library": "TangoAntd",
      "type": "baseDependency",
      "designerResources": ["https://tango.1micro.top/components/designer.js"]
    },
    "react": {
      "version": "19.2.5",
      "type": "baseDependency"
    },
    "react-dom": {
      "version": "19.2.5",
      "type": "baseDependency"
    },
    "antd": {
      "version": "6.3.7",
      "type": "dependency"
    },
    "@ant-design/icons": {
      "version": "6.2.2",
      "type": "dependency"
    },
    "clsx": { "version": "2.1.1", "library": "clsx", "type": "dependency" },
    "ky": { "version": "1.14.0", "library": "ky", "type": "dependency" },
    "@ant-design/pro-components": {
      "version": "3.1.12-0",
      "type": "dependency"
    },
    "@rc-component/pagination": { "version": "1.2.0" },
    "@rc-component/picker": { "version": "1.10.0" }
  },
  "babel": {
    "regex": {
      "@umijs/max": "#libs/mock__@umijs_max",
      "#src/hooks/use-access": "#libs/mock__access",
      "#src/router[^\"]*": "#libs/mock__router",
      "#src/(layout|store)/[^\"]+": "#libs/mock__$1"
    }
  }
}
