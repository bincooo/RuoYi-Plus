{
  "designerConfig": {
    "autoFormatCode": true,
    "autoGenerateComponentId": false
  },
  "packages": {
    "@loccdn/antd": {
      "description": "低代码中后台应用基础物料",
      "version": "0.2.6",
      "library": "TangoAntd",
      "type": "baseDependency",
      "designerResources": ["https://tango.1micro.top/components/designer.js"]
    },
    "@bingco/react-reject": {
      "description": "低代码标记注入器",
      "version": "1.0.1-dev14",
      "type": "baseDependency"
    },
    "react": {
      "version": "19.2.7",
      "type": "baseDependency"
    },
    "react-dom": {
      "version": "19.2.7",
      "type": "baseDependency"
    }
  },
  "babel": {
    "regex": {
      "@umijs/max": "#libs/mock__@umijs_max",
      "#src/hooks/use-([^\"]+)": "#libs/mock__$1",
      "#src/router[^\"]*": "#libs/mock__router",
      "#src/(layout|store)/[^\"]+": "#libs/mock__$1"
    }
  }
}
